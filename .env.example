# ============================================================
# HiringBase — Environment Configuration
# ============================================================

# ————————————————————————————————————————————————————————————
# APP
# ————————————————————————————————————————————————————————————
APP_NAME="HiringBase"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-256-bit-random-secret-key-min-32-chars
API_V1_PREFIX=/api/v1

# ————————————————————————————————————————————————————————————
# DATABASE (Neon Cloud PostgreSQL)
# ————————————————————————————————————————————————————————————
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://username:password@ep-xyz-123.us-east-1.aws.neon.tech/neondb?ssl=require

# ————————————————————————————————————————————————————————————
# JWT AUTH
# ————————————————————————————————————————————————————————————
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ————————————————————————————————————————————————————————————
# CLOUDFLARE R2 (S3-Compatible)
# ————————————————————————————————————————————————————————————
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=smart-resume-uploads
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ————————————————————————————————————————————————————————————
# AI / LLM
# ————————————————————————————————————————————————————————————
# HuggingFace Inference API for Qwen3 / Llama3
HF_API_TOKEN=hf_your_huggingface_token_here
HF_LLM_MODEL=Qwen/Qwen3-8B
HF_LLM_API_URL=https://api-inference.huggingface.co/models/Qwen/Qwen3-8B

# OpenRouter / alternative LLM API (fallback)
OPENROUTER_API_KEY=sk-or-v1-your-key

# Groq API (High Speed LLM)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=qwen/qwen3-32b

# Mistral Document AI (OCR)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-ocr-latest

# ————————————————————————————————————————————————————————————
# AI MODELS LOCAL / REMOTE
# ————————————————————————————————————————————————————————————
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_md

# ————————————————————————————————————————————————————————————
# SCORING DEFAULTS
# ————————————————————————————————————————————————————————————
DEFAULT_SKILL_WEIGHT=40
DEFAULT_EXPERIENCE_WEIGHT=20
DEFAULT_EDUCATION_WEIGHT=10
DEFAULT_PORTFOLIO_WEIGHT=10
DEFAULT_SOFT_SKILL_WEIGHT=10
DEFAULT_ADMIN_WEIGHT=10

# ————————————————————————————————————————————————————————————
# EMAIL (SMTP for notifications — optional MVP+)
# ————————————————————————————————————————————————————————————
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smartresume.local

# ————————————————————————————————————————————————————————————
# REDIS (Upstash Redis — for Distributed Tasks)
# ————————————————————————————————————————————————————————————
# Format: rediss://default:password@host:port
REDIS_URL=rediss://default:your-token@your-host.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://your-host.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ————————————————————————————————————————————————————————————
# RATE LIMITING
# ————————————————————————————————————————————————————————————
RATE_LIMIT_PER_MINUTE=60
